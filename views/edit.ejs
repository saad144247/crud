<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
  <style>
    body { 
        font-family: 'Times New Roman', serif; 
        background-color: #e5e5e5; 
        padding-top: 50px;
    }

    .container { 
        background: #ffffff; 
        padding: 20px; 
        width: 320px; 
        margin: 0 auto; 
        border: 1px solid #000; 
    }

    h1 { 
        font-size: 20px; 
        color: black; 
        text-decoration: underline;
        margin-top: 0;
    }

    input[type="text"] { 
        width: 90%; 
        padding: 8px; 
        margin-bottom: 15px; 
        border: 1px solid #555;
    }

    .update-btn { 
        background-color: blue; 
        color: white; 
        border: 1px solid black; 
        padding: 10px; 
        cursor: pointer; 
        width: 100%;
        font-size: 16px;
    }

    .back-link { 
        display: inline-block; 
        margin-top: 20px; 
        color: blue; 
        font-size: 13px;
    }
</style>
</head>
<body>

    <div class="container">
        <h1>update task</h1>
        <form action="/tasks/<%= task.id %>?_method=PUT" method="POST">
            <input type="text" name="title" value="<%= task.title %>" required>
            <button type="submit" class="update-btn">Save Changes</button>
        </form>
        <a href="/" class="back-link">cancel and go back</a>
    </div>

</body>
</html>